<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selamat Datang, Admin 👑"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dashboard Admin"
        android:textSize="14sp"
        android:textColor="#888888"
        android:paddingBottom="24dp"/>

    <!-- Kelola Destinasi -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDestinasi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏝️  Kelola Destinasi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah, edit, hapus destinasi"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="24sp" android:textColor="#888888"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Kelola User -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥  Kelola User"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat dan hapus user terdaftar"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="24sp" android:textColor="#888888"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Lihat Tiket -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTiket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎫  Semua Tiket"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konfirmasi dan batalkan tiket"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="24sp" android:textColor="#888888"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Browse Destinasi seperti User -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBrowse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="#E8F5E9">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍  Browse Destinasi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat dan booking seperti user"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textSize="24sp" android:textColor="#2E7D32"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:backgroundTint="#E53935"
        android:textColor="#FFFFFF"
        android:padding="14dp"
        android:textSize="16sp"/>

</LinearLayout>